{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protocol.writersproof.com/schemas/evidence-v1.json",
  "title": "Evidence Packet",
  "description": "A self-contained proof of documented authorship matching draft-condrey-rats-pop",
  "type": "object",
  "required": [
    "version",
    "profile_uri",
    "packet_id",
    "created_at",
    "document",
    "checkpoints"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Evidence packet format version (CDDL key 1)",
      "const": 1
    },
    "profile_uri": {
      "type": "string",
      "description": "Profile URI defining verification requirements (CDDL key 2)",
      "format": "uri"
    },
    "packet_id": {
      "type": "string",
      "description": "Unique UUID for this packet (CDDL key 3)",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "description": "Packet creation timestamp (CDDL key 4)",
      "format": "date-time"
    },
    "document": {
      "description": "Reference to the witnessed document (CDDL key 5)",
      "$ref": "#/$defs/DocumentRef"
    },
    "checkpoints": {
      "type": "array",
      "description": "Unbroken chain of witnessed document states (CDDL key 6)",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/Checkpoint"
      }
    },
    "attestation_tier": {
      "type": "integer",
      "description": "Device assurance level: 1=Software, 2=Attested, 3=Hardware-Bound, 4=Hardened (CDDL key 7)",
      "enum": [1, 2, 3, 4]
    },
    "limitations": {
      "type": "array",
      "description": "Disclosures about evidence collection (CDDL key 8)",
      "items": {
        "type": "string"
      }
    },
    "profile": {
      "description": "Profile-specific declaration (CDDL key 9)",
      "$ref": "#/$defs/ProfileDeclaration"
    },
    "presence_proofs": {
      "type": "array",
      "description": "Presence verification proofs (CDDL key 10)",
      "items": {
        "$ref": "#/$defs/PresenceChallenge"
      }
    },
    "content_tier": {
      "type": "integer",
      "description": "Evidence complexity tier: 1=Core, 2=Enhanced, 3=Maximum (CDDL key 13)",
      "enum": [1, 2, 3]
    }
  },
  "$defs": {
    "DocumentRef": {
      "type": "object",
      "required": ["content_hash", "byte_length"],
      "properties": {
        "content_hash": { "$ref": "#/$defs/HashValue" },
        "filename": { "type": "string" },
        "byte_length": { "type": "integer", "minimum": 0 },
        "char_count": { "type": "integer", "minimum": 0 }
      }
    },
    "Checkpoint": {
      "type": "object",
      "required": ["sequence", "checkpoint_id", "timestamp", "content_hash", "checkpoint_hash"],
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "checkpoint_id": { "type": "string", "format": "uuid" },
        "timestamp": { "type": "string", "format": "date-time" },
        "content_hash": { "$ref": "#/$defs/HashValue" },
        "char_count": { "type": "integer", "minimum": 0 },
        "prev_hash": { "$ref": "#/$defs/HashValue" },
        "checkpoint_hash": { "$ref": "#/$defs/HashValue" },
        "process_proof": { "$ref": "#/$defs/ProcessProof" },
        "jitter_binding": { "$ref": "#/$defs/JitterBinding" }
      }
    },
    "HashValue": {
      "type": "object",
      "required": ["algorithm", "digest"],
      "properties": {
        "algorithm": { "type": "integer", "enum": [1, 2, 3], "description": "1=SHA256, 2=SHA384, 3=SHA512" },
        "digest": { "type": "string", "description": "Hex-encoded hash digest" }
      }
    },
    "ProcessProof": {
      "type": "object",
      "required": ["algorithm", "input", "merkle_root", "claimed_duration_ms"],
      "properties": {
        "algorithm": { "type": "integer", "enum": [20, 21] },
        "input": { "type": "string", "description": "Seed digest (hex)" },
        "merkle_root": { "type": "string", "description": "Merkle root of VDF steps (hex)" },
        "claimed_duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "JitterBinding": {
      "type": "object",
      "required": ["entropy_estimate_centibits", "jitter_seal"],
      "properties": {
        "intervals_ms": { "type": "array", "items": { "type": "integer" } },
        "entropy_estimate_centibits": { "type": "integer" },
        "jitter_seal": { "type": "string", "description": "HMAC-SHA256 digest (hex)" }
      }
    },
    "ProfileDeclaration": {
      "type": "object",
      "required": ["profile_id"],
      "properties": {
        "profile_id": { "type": "string" },
        "feature_flags": { "type": "array", "items": { "type": "integer" } }
      }
    },
    "PresenceChallenge": {
      "type": "object",
      "required": ["challenge_nonce", "device_signature", "response_time"],
      "properties": {
        "challenge_nonce": { "type": "string", "description": "Hex or Base64 nonce" },
        "device_signature": { "type": "string", "description": "COSE_Sign1 signature" },
        "response_time": { "type": "string", "format": "date-time" }
      }
    }
  }
}
