# WritersLogic Environment Variables
# Copy to .env and customize (never commit .env!)

# Database paths (defaults shown)
WLD_EVENT_STORE=/home/user/.writerslogic/events.db
WLD_MMR_PATH=/home/user/.writerslogic/mmr.bin
WLD_CONFIG=/home/user/.writerslogic/config.toml

# Signing key path
WLD_SIGNING_KEY=/home/user/.ssh/wld_signing_key

# TPM configuration (optional)
WLD_TPM_DEVICE=/dev/tpmrm0
WLD_TPM_SIMULATOR=false
TPM2TOOLS_TCTI=device:/dev/tpmrm0

# External timestamping (optional)
WLD_TSA_URL=https://freetsa.org/tsr
WLD_OTS_CALENDAR=https://a.pool.opentimestamps.org

# Logging
WLD_LOG_LEVEL=info
WLD_AUDIT_LOG=/var/log/wld/audit.log

# Development/testing
WLD_DEBUG=false
WLD_TEST_MODE=false
