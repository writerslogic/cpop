#!/bin/bash
# postinst script for wld

set -e

case "$1" in
    configure)
        # Create wld system user if it doesn't exist
        if ! getent passwd wld >/dev/null 2>&1; then
            adduser --system --group --home /var/lib/wld \
                --no-create-home --shell /usr/sbin/nologin \
                --gecos "WritersLogic Daemon" wld
        fi

        # Create required directories
        install -d -m 750 -o wld -g wld /var/lib/wld
        install -d -m 750 -o wld -g wld /var/log/wld
        install -d -m 755 /etc/wld

        # Create default config if it doesn't exist
        if [ ! -f /etc/wld/config.toml ]; then
            if [ -f /etc/wld/config.toml.default ]; then
                cp /etc/wld/config.toml.default /etc/wld/config.toml
                chmod 640 /etc/wld/config.toml
                chown root:wld /etc/wld/config.toml
            fi
        fi

        # Create environment file if it doesn't exist
        if [ ! -f /etc/wld/environment ]; then
            cat > /etc/wld/environment << 'EOF'
# Environment variables for wld
# WLD_LOG_LEVEL=info
# WLD_DATA_DIR=/var/lib/wld
# WLD_CONFIG=/etc/wld/config.toml
EOF
            chmod 640 /etc/wld/environment
            chown root:wld /etc/wld/environment
        fi

        # Reload systemd daemon
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
