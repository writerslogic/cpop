{
  "manifest_version": 3,
  "name": "WritersProof",
  "version": "1.0.0",
  "description": "Prove you wrote it. WritersProof captures cryptographic evidence of your writing process in Google Docs, Overleaf, Medium, and more.",
  "homepage_url": "https://writerslogic.com",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://www.overleaf.com/*",
    "https://medium.com/*",
    "https://notion.so/*",
    "https://www.notion.so/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cpoe@writerslogic.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/document/*",
        "https://www.overleaf.com/project/*",
        "https://medium.com/p/*",
        "https://medium.com/new-story*",
        "https://notion.so/*",
        "https://www.notion.so/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
