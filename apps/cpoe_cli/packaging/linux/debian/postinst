#!/bin/bash
# postinst script for cpop

set -e

case "$1" in
    configure)
        # Create cpop system user if it doesn't exist
        if ! getent passwd cpop >/dev/null 2>&1; then
            adduser --system --group --home /var/lib/cpop \
                --no-create-home --shell /usr/sbin/nologin \
                --gecos "CPOP Daemon" cpop
        fi

        # Create required directories
        install -d -m 750 -o cpop -g cpop /var/lib/cpop
        install -d -m 750 -o cpop -g cpop /var/log/cpop
        install -d -m 755 /etc/cpop

        # Create default config if it doesn't exist
        if [ ! -f /etc/cpop/config.toml ]; then
            if [ -f /etc/cpop/config.toml.default ]; then
                cp /etc/cpop/config.toml.default /etc/cpop/config.toml
                chmod 640 /etc/cpop/config.toml
                chown root:cpop /etc/cpop/config.toml
            fi
        fi

        # Create environment file if it doesn't exist
        if [ ! -f /etc/cpop/environment ]; then
            cat > /etc/cpop/environment << 'EOF'
# Environment variables for cpop
# CPOP_LOG_LEVEL=info
# CPOP_DATA_DIR=/var/lib/cpop
# CPOP_CONFIG=/etc/cpop/config.toml
EOF
            chmod 640 /etc/cpop/environment
            chown root:cpop /etc/cpop/environment
        fi

        # Reload systemd daemon
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
