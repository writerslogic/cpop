#!/bin/bash
# postrm script for cpop

set -e

case "$1" in
    purge)
        # Remove data directories on purge
        rm -rf /var/lib/cpop
        rm -rf /var/log/cpop
        rm -rf /etc/cpop

        # Remove cpop user
        if getent passwd cpop >/dev/null 2>&1; then
            deluser --quiet --system cpop || true
        fi

        # Remove cpop group
        if getent group cpop >/dev/null 2>&1; then
            delgroup --quiet --system cpop || true
        fi

        # Reload systemd daemon
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
        ;;

    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Reload systemd daemon
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
        ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
