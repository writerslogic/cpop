#!/usr/bin/make -f

# Debian rules file for wld

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export CARGO_TERM_COLOR = never

# Version information
VERSION := $(shell dpkg-parsechangelog -S Version | cut -d- -f1)
COMMIT := $(shell git rev-parse --short HEAD 2>/dev/null || echo "unknown")
BUILD_TIME := $(shell date -u +"%Y-%m-%dT%H:%M:%SZ")

%:
	dh $@

override_dh_auto_clean:
	cargo clean || true
	rm -rf bin/

override_dh_auto_build:
	# Build CLI binary
	cargo build --release --package wld_cli
	mkdir -p bin/
	cp target/release/wld bin/wld
	cp target/release/wld-native-messaging-host bin/ || true

override_dh_auto_test:
	cargo test --package wld_cli

override_dh_auto_install:
	# Install binaries
	install -D -m 755 bin/wld debian/wld/usr/bin/wld

	# Install man pages
	install -D -m 644 ../../docs/man/wld.1 debian/wld/usr/share/man/man1/wld.1

	# Install systemd units (if present)
	if [ -d packaging/linux/systemd ]; then \
		install -D -m 644 packaging/linux/systemd/wld.service debian/wld/lib/systemd/system/wld.service; \
		install -D -m 644 packaging/linux/systemd/wld-user.service debian/wld/usr/lib/systemd/user/wld.service; \
	fi

	# Install documentation
	install -D -m 644 ../../LICENSE debian/wld/usr/share/doc/wld/LICENSE
	install -D -m 644 README.md debian/wld/usr/share/doc/wld/README.md

override_dh_installsystemd:
	dh_installsystemd --name=wld
	dh_installsystemd --name=wld --user

override_dh_compress:
	dh_compress -X.md
