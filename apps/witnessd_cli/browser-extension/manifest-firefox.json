{
  "manifest_version": 2,
  "name": "Witnessd",
  "version": "1.0.0",
  "description": "Cryptographic proof-of-process evidence for browser-based writing. Witness your creative process in Google Docs, Overleaf, Medium, and more.",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "witnessd@writerslogic.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/document/*",
        "https://www.overleaf.com/project/*",
        "https://medium.com/p/*",
        "https://medium.com/new-story*",
        "https://notion.so/*",
        "https://www.notion.so/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
